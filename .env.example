# Copy to `.env` in the project root (never commit real `.env`).

# --- PostgreSQL (already running on your VM or another host) ---
# The BACKEND CONTAINER must reach this host:port. Rules:
# - Remote VM: use that server's IP/DNS and the port Postgres listens on (e.g. 3893).
# - Postgres on the SAME machine as Docker: use the VM LAN IP, or host.docker.internal
#   if Postgres is bound on the host (compose already sets extra_hosts for Linux).
# - Do NOT use 127.0.0.1 here — inside the container that means the container itself.
# Ensure PostgreSQL listen_addresses / pg_hba.conf / firewall allow this client.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@DB_HOST:DB_PORT/DB_NAME
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@DB_HOST:DB_PORT/DB_NAME

# --- CORS: browser origins allowed to call the API directly ---
# Include the URL users open in the browser (scheme + host + port), e.g.:
#   http://YOUR_PUBLIC_IP:3894
#   https://your.domain  (if TLS terminates in front of nginx)
CORS_ORIGINS=http://localhost:3894,http://127.0.0.1:3894,http://localhost:5173,http://127.0.0.1:5173

DEBUG=false

# Frontend Docker build: leave empty so the SPA uses same-origin /api (nginx proxies to backend).
# VITE_API_URL=
